# Dependencies (installed inside Docker using npm install)
node_modules
npm-debug.log

# Build results (generated by the container itself)
dist
build
.next
out

# Environment variables and secrets
.env
.env.*
!.env.example  # Exception for .env.example, which is not ignored

# Git and IDE settings
.git
.gitignore
.vscode
.idea
*.swp  # Temporary swap files, typically from editors like Vim
*.log  # Log files

# Docker files (not needed inside the image itself)
Dockerfile
docker-compose.yml
.dockerignore